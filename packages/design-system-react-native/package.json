{
  "name": "@metamask/design-system-react-native",
  "version": "0.32.0",
  "description": "Design System React Native",
  "keywords": [
    "MetaMask",
    "Ethereum"
  ],
  "homepage": "https://github.com/MetaMask/metamask-design-system/tree/main/packages/design-system-react-native#readme",
  "bugs": {
    "url": "https://github.com/MetaMask/metamask-design-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaMask/metamask-design-system.git"
  },
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "ts-bridge --project tsconfig.build.json --verbose --clean --no-references && cp -r src/components/Icon/assets dist/components/Icon/",
    "changelog:update": "../../scripts/update-changelog.sh @metamask/design-system-react-native",
    "changelog:validate": "../../scripts/validate-changelog.sh @metamask/design-system-react-native",
    "create-component:react-native": "tsx scripts/create-component",
    "publish:preview": "yarn npm publish --tag preview",
    "since-latest-release": "../../scripts/since-latest-release.sh",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --reporters=jest-silent-reporter",
    "test:clean": "NODE_OPTIONS=--experimental-vm-modules jest --clearCache",
    "test:verbose": "NODE_OPTIONS=--experimental-vm-modules jest --verbose",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch"
  },
  "dependencies": {
    "@metamask/design-system-shared": "workspace:^",
    "fast-text-encoding": "^1.0.6",
    "react-native-jazzicon": "^0.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@babel/preset-typescript": "^7.23.3",
    "@figma/code-connect": "^1.4.8",
    "@gorhom/bottom-sheet": "^5.1.3",
    "@metamask/auto-changelog": "^6.1.1",
    "@metamask/design-system-twrnc-preset": "workspace:^",
    "@metamask/design-tokens": "workspace:^",
    "@metamask/utils": "^11.11.0",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/typescript-config": "0.81.5",
    "@storybook/react-native": "10.4.7",
    "@testing-library/react-native": "^13.3.3",
    "@ts-bridge/cli": "^0.6.3",
    "@types/babel__preset-env": "^7",
    "@types/fast-text-encoding": "^1",
    "@types/jest": "^27.4.1",
    "@types/node": "^16.18.54",
    "@types/react": "^19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.7.0",
    "deepmerge": "^4.2.2",
    "jest": "^29.7.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-native-worklets": "patch:react-native-worklets@npm%3A0.5.1#~/.yarn/patches/react-native-worklets-npm-0.5.1-dcf1422a19.patch",
    "react-test-renderer": "19.1.0",
    "storybook": "10.4.6",
    "ts-jest": "^29.2.5",
    "tsx": "^4.20.6",
    "typescript": "~5.2.2"
  },
  "peerDependencies": {
    "@metamask/design-system-twrnc-preset": "^0.6.0",
    "@metamask/design-tokens": "^8.2.0",
    "@metamask/utils": "^11.11.0",
    "lodash": "^4.17.21",
    "react": ">=18.2.0",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.25.0",
    "react-native-reanimated": ">=3.17.0",
    "react-native-safe-area-context": ">=5.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
